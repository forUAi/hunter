{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hunter child investigation result summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "task_id", "target_repository", "target_commit", "status", "coverage_file", "findings_file", "evidence_file", "target_unchanged"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "target_repository": {"type": "string", "minLength": 1},
    "target_commit": {"type": "string", "minLength": 1},
    "status": {"enum": ["COMPLETE", "ABSTAINED", "INCOMPLETE"]},
    "coverage_file": {"type": "string", "minLength": 1},
    "findings_file": {"type": "string", "minLength": 1},
    "evidence_file": {"type": "string", "minLength": 1},
    "target_unchanged": {"const": true}
  }
}
