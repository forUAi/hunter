{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hunter managed run manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "target_repository", "target_repo_path", "target_commit", "results_repo_path", "results_branch", "taxonomy_file", "taxonomy_version", "accelerator_status", "created_at", "initial_target_snapshot", "budgets"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "target_repository": {"type": "string", "minLength": 3},
    "target_repo_path": {"type": "string", "minLength": 1},
    "target_commit": {"type": "string", "pattern": "^[0-9a-fA-F]{40,64}$"},
    "results_repo_path": {"type": "string", "minLength": 1},
    "results_branch": {"type": "string", "minLength": 1},
    "taxonomy_file": {"type": "string", "minLength": 1},
    "taxonomy_version": {"type": "string", "minLength": 1},
    "accelerator_status": {"enum": ["COMPLETE", "PARTIAL"]},
    "created_at": {"type": "string", "minLength": 1},
    "initial_target_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_sha", "status_porcelain", "diff_sha256"],
      "properties": {
        "commit_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40,64}$"},
        "status_porcelain": {"type": "string"},
        "diff_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_total_acu", "parent_orchestrator_acu", "investigator_child_acu", "coverage_auditor_acu", "validator_pack_acu", "critic_acu", "maximum_investigation_children", "maximum_validation_children", "maximum_retry_count"],
      "properties": {
        "maximum_total_acu": {"type": "integer", "minimum": 1},
        "parent_orchestrator_acu": {"type": "integer", "minimum": 1},
        "investigator_child_acu": {"type": "integer", "minimum": 1},
        "coverage_auditor_acu": {"type": "integer", "minimum": 1},
        "validator_pack_acu": {"type": "integer", "minimum": 1},
        "critic_acu": {"type": "integer", "minimum": 1},
        "maximum_investigation_children": {"type": "integer", "minimum": 1, "maximum": 7},
        "maximum_validation_children": {"type": "integer", "minimum": 1, "maximum": 5},
        "maximum_retry_count": {"type": "integer", "minimum": 0, "maximum": 2}
      }
    }
  }
}
