{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hunter fresh-context Critic result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "target_repository", "target_commit", "produced_by", "decisions"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "target_repository": {"type": "string", "minLength": 1},
    "target_commit": {"type": "string", "minLength": 1},
    "produced_by": {"type": "string", "minLength": 1},
    "decisions": {"type": "array", "items": {"$ref": "#/$defs/decision"}}
  },
  "$defs": {
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "verdict", "reason", "corrected_severity", "corrected_cvss_vector", "contradicting_evidence"],
      "properties": {
        "finding_id": {"type": "string", "minLength": 1},
        "verdict": {"enum": ["CONFIRMED", "DOWNGRADED", "REJECTED"]},
        "reason": {"type": "string", "minLength": 1},
        "corrected_severity": {"type": ["string", "null"]},
        "corrected_cvss_vector": {"type": ["string", "null"]},
        "contradicting_evidence": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
